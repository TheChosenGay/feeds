{
  "title": "Go Runtime",
  "uid": "go-runtime",
  "panels": [
    {
      "title": "Goroutines",
      "type": "timeseries",
      "targets": [
        { "expr": "go_goroutines", "legendFormat": "{{service_name}}" }
      ]
    },
    {
      "title": "Memory Allocated (MB)",
      "type": "timeseries",
      "targets": [
        { "expr": "go_memstats_alloc_bytes / 1024 / 1024", "legendFormat": "{{service_name}}" }
      ]
    },
    {
      "title": "GC Duration (ms)",
      "type": "timeseries",
      "targets": [
        { "expr": "go_gc_duration_seconds", "legendFormat": "{{service_name}} {{quantile}}" }
      ]
    }
  ]
}
